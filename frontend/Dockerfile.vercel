FROM node:20-alpine AS build-stage

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY . .

RUN npm run build

FROM node:20-alpine AS production-stage
WORKDIR /app

COPY --from=build-stage /app/dist ./dist
RUN npm install -g serve

EXPOSE 80
CMD ["sh", "-c", "serve -s dist -l $PORT"]
# CMD ["nginx", "-g", "daemon off;"]